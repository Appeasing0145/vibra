{
  "name": "vibra",
  "version": "1.0.0",
  "description": "JavaScript and WebAssembly bindings for Vibra.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shazam": {
      "types": "./dist/shazam.d.ts",
      "import": "./dist/shazam.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "vibrajs": "./dist/cli.js"
  },
  "scripts": {
    "start": "node dist/cli.js",
    "build": "tsc && npm run copy:wasm",
    "build:wasm": "./build-wasm.sh",
    "copy:wasm": "cp src/vibra.js dist/vibra.js && cp src/vibra.wasm dist/vibra.wasm && cp src/vibra.d.ts dist/vibra.d.ts",
    "prestart": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "",
  "license": "GPL-3.0-only",
  "dependencies": {
    "axios": "^1.6.7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.3.3"
  }
}
