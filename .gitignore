!cli/args

# Unignore Dockerfile
!Dockerfile

# Node.js
node_modules/
npm-debug.log
yarn-error.log
yarn.lock

# TypeScript
*.tsbuildinfo
dist/

# Python
*.egg-info/
.venv/
venv/
wheelhouse/

# CLion
.idea/
cmake-build-debug/
cmake-build-release/
